---
import type { ProjectData } from "../../lib/projects";

const { title, tags, category, url, code_url, short_description } =
    Astro.props as ProjectData;
---

<header class="header">
    <p hidden class="category">{category}</p>
    <h1>{title}</h1>
    <p class="short_description">{short_description}</p>
    <div class="actions">
        {
            url && (
                <a
                    class="btn btn-light"
                    href={url}
                    target="_blank"
                    rel="noreferrer noopener"
                >
                    open project
                </a>
            )
        }
        {
            code_url && (
                <a
                    class="btn btn-dark"
                    href={code_url}
                    target="_blank"
                    rel="noreferrer noopener"
                >
                    view source code
                </a>
            )
        }
    </div>
</header>
<div class="tags_container">
    <h3>Skills</h3>
    <ul class="tags_list">
        {tags.map((tag) => <li class="btn btn-light">{tag}</li>)}
    </ul>
</div>

<style lang="scss">
    @use "../../../styles" as *;

    .header {
        text-align: center;
        background: $success;
        padding: 8rem 2rem;

        .category {
            @include text_style("body", "book");
            text-transform: capitalize;
        }

        h1 {
            max-width: 900px;
            margin-left: auto;
            margin-right: auto;
            margin-bottom: 0.5rem;
        }

        .short_description {
            @include text_style("body-lg", "medium");
            margin-bottom: 4rem;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        .actions {
            display: inline-block;

            a {
                margin: 0 0.25rem;
            }
        }

        @media (max-width: $mq-phone) {
            padding: 4rem 1.5rem;

            .category {
                @include text_style("body", "book");
            }
            h1 {
                @include text_style("h2", "extra-bold");
                margin-bottom: 2rem;
            }

            .short_description {
                @include text_style("body-lg", "book");
            }
        }
    }

    .tags_container {
        margin: 0 auto;
        padding: 4rem 2rem;
        max-width: 900px;

        .tags_list {
            display: flex;
            flex-wrap: wrap;

            li {
                text-transform: none;
                margin-right: 0.5rem;
            }
        }
    }
</style>
